# Copy to .env and adjust. phi talks to a single OpenAI-compatible endpoint:
# the litellm proxy deployed at ai.ukehome.top.
PHI_BASE_URL=https://ai.ukehome.top/v1
PHI_API_KEY=
PHI_DEFAULT_MODEL=
PHI_REQUEST_TIMEOUT_SECONDS=180
PHI_SESSION_DIR=~/.phi/sessions
PHI_COMPACTION_ENABLED=true
PHI_COMPACTION_RESERVE_TOKENS=16384
PHI_COMPACTION_KEEP_RECENT_TOKENS=20000
PHI_COMPACTION_SUMMARY_MAX_TOKENS=4096
# PHI_COMPACTION_MAX_INPUT_TOKENS=
